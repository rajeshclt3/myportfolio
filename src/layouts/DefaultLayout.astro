---
import '../styles/globals.css';
import TopNav from '../components/TopNav.astro';
import siteData from '../../content/site.json';
import ProfileCard from '../components/ProfileCard.astro';
const { navItems, profile } = siteData;

const { slot, title = 'Portfolio' } = Astro.props;
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen">
    <div class="max-w-6xl mx-auto px-6 py-8 md:py-10">
      <TopNav items={navItems} currentPath={Astro.url.pathname} />
    </div>
    <div class="max-w-6xl mx-auto px-6 pb-12 grid grid-cols-12 gap-8">
      <aside class="col-span-12 md:col-span-3">
        <div class="md:sticky md:top-28">
          <slot name="sidebar"><ProfileCard {...profile} /></slot>
        </div>
      </aside>
      <main class="col-span-12 md:col-span-9">
        <slot />
      </main>
    </div>
  </body>
</html>
