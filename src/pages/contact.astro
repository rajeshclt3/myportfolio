---
import DefaultLayout from '../layouts/DefaultLayout.astro';
import ProfileCard from '../components/ProfileCard.astro';
import SidebarNav from '../components/SidebarNav.astro';
import ContactForm from '../components/ContactForm.astro';

const navItems = [
  { label: 'Home', href: '/' },
  { label: 'Resume', href: '/resume' },
  { label: 'Work', href: '/work' },
  { label: 'Contact', href: '/contact' }
];
---
<DefaultLayout title="Contact - Portfolio">
  <div slot="sidebar">
    <ProfileCard name="Alex Rivera" title="Embedded Systems & AI Engineer" />
    <div class="mt-6">
      <SidebarNav items={navItems} />
    </div>
  </div>

  <section id="contact">
    <h2 class="text-2xl font-semibold mb-4">Get in touch</h2>
    <ContactForm endpoint="https://formsubmit.co/you@example.com" />
  </section>
</DefaultLayout>
