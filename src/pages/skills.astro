---
import DefaultLayout from '../layouts/DefaultLayout.astro';
import ProfileCard from '../components/ProfileCard.astro';
import SkillSection from '../components/SkillSection.astro';
import Pill from '../components/Pill.astro';
import siteData from '../../content/site.json';
const { profile } = siteData;
import skillsData from '../../content/skills.json';
const { skillPageIntro, skillSections, orchestrationSkills } = skillsData;
---

<DefaultLayout title="Skills - Portfolio">
  <div slot="sidebar">
    <ProfileCard {...profile} />
  </div>

  <section class="space-y-8">
    <div>
      <p class="text-[11px] uppercase tracking-[0.2em] text-accent font-semibold">{skillPageIntro.eyebrow}</p>
      <h1 class="text-4xl font-extrabold mt-2">Skills & <span class="text-accent">Technologies</span></h1>
      <p class="text-gray-600 mt-3 max-w-2xl">{skillPageIntro.subtitle}</p>
    </div>

    {skillSections.map((section) => <SkillSection title={section.title} items={section.items} />)}

    <div class="card">
      <h3 class="text-[11px] uppercase tracking-[0.2em] text-accent font-semibold mb-4">Modern AI Orchestration</h3>
      <div class="flex flex-wrap gap-2">
        {orchestrationSkills.map((item) => <Pill text={item} size="md" />)}
      </div>
    </div>
  </section>
</DefaultLayout>
