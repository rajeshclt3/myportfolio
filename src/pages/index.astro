---
import DefaultLayout from '../layouts/DefaultLayout.astro';
import ProfileCard from '../components/ProfileCard.astro';
import SidebarNav from '../components/SidebarNav.astro';
import { profile, navItems } from '../data/site';
import Hero from '../components/Hero.astro';
import CTASection from '../components/CTASection.astro';
---

<DefaultLayout title="Home - Portfolio">
  <div slot="sidebar">
    <ProfileCard {...profile} />
    <div class="mt-6">
      <SidebarNav items={navItems} />
    </div>
  </div>

  <Hero title={"Architecting the \n Intelligence of Things."} subtitle={"Bridging hardware precision and intelligent software orchestration."} badges={["Embedded", "AI/ML", "UI"]} />

  <section>
    <h2 class="text-2xl font-semibold mb-4">Select Case Studies</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <!-- ProjectCard instances will be added here later -->
      <CTASection title="Ready to start a technical project?" subtitle="Currently accepting select contracts for Q4 2026." primary={{label:'Start Consultation'}} secondary={{label:'View Process'}} />
    </div>
  </section>
</DefaultLayout>
