---
import DefaultLayout from '../layouts/DefaultLayout.astro';
import ProfileCard from '../components/ProfileCard.astro';
import SidebarNav from '../components/SidebarNav.astro';
import { profile, navItems } from '../data/site';
import ProjectCard from '../components/ProjectCard.astro';

const projects = [
  { title: 'Neural Agriculture Monitor', image: '/placeholder.png', categories: ['AI/ML'], excerpt: 'Edge AI for precision agriculture.' },
  { title: 'DeepSea Explorer Mk IV', image: '/placeholder.png', categories: ['Robotics'], excerpt: 'Low-latency tele-operation firmware.' }
];
---
<DefaultLayout title="Work - Portfolio">
  <div slot="sidebar">
    <ProfileCard {...profile} />
    <div class="mt-6">
      <SidebarNav items={navItems} />
    </div>
  </div>

  <section>
    <h2 class="text-2xl font-semibold mb-6">Selected Works</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {projects.map(p => <ProjectCard {...p} />)}
    </div>
  </section>
</DefaultLayout>
