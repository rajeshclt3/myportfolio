---
import DefaultLayout from '../layouts/DefaultLayout.astro';
import ProfileCard from '../components/ProfileCard.astro';
import ExperienceCard from '../components/ExperienceCard.astro';
import Pill from '../components/Pill.astro';
import siteData from '../../content/site.json';
const { profile } = siteData;
import resumeData from '../../content/resume.json';
const { professionalSummary, experiences, workSkills, softSkills, education, awards } = resumeData;
---
<DefaultLayout title="Resume - Portfolio">
  <div slot="sidebar">
    <ProfileCard {...profile} />
  </div>

  <section class="space-y-8">
    <header>
      <p class="text-[11px] uppercase tracking-[0.2em] text-accent font-semibold mb-2">Professional Summary</p>
      <p class="text-gray-700 leading-7 max-w-3xl">{professionalSummary}</p>
    </header>

    <div>
      <h2 class="text-3xl font-bold tracking-tight mb-5 text-gray-900">Work Experience</h2>
      <div class="space-y-3">
        {experiences.map((exp) => <ExperienceCard {...exp} />)}
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div class="card">
        <h3 class="text-lg font-semibold mb-4">Work Skills</h3>
        <div class="flex flex-wrap gap-2">
          {workSkills.map((skill) => <Pill text={skill} />)}
        </div>
      </div>
      <div class="card">
        <h3 class="text-lg font-semibold mb-4">Soft Skills</h3>
        <div class="flex flex-wrap gap-2">
          {softSkills.map((skill) => <Pill text={skill} />)}
        </div>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div class="card">
        <h3 class="text-lg font-semibold mb-4">Education</h3>
        <ul class="space-y-2 text-sm text-gray-700 list-disc pl-5">
          {education.map((item) => <li>{item}</li>)}
        </ul>
      </div>
      <div class="card">
        <h3 class="text-lg font-semibold mb-4">Awards</h3>
        <ul class="space-y-2 text-sm text-gray-700 list-disc pl-5">
          {awards.map((item) => <li>{item}</li>)}
        </ul>
      </div>
    </div>
  </section>
</DefaultLayout>
