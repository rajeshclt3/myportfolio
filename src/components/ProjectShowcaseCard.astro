---
import ExpandableText from './ExpandableText.astro';
import Pill from './Pill.astro';

export interface Props {
  title: string;
  category: string;
  overview: string;
  details?: string[];
  visualTitle?: string;
  visualSubtitle?: string;
  theme?: 'ocean' | 'forest' | 'ember' | 'slate';
}

const {
  title,
  category,
  overview,
  details = [],
  visualTitle,
  visualSubtitle,
  theme = 'slate'
} = Astro.props as Props;

const themeClasses = {
  ocean: 'from-slate-950 via-slate-800 to-cyan-700',
  forest: 'from-slate-950 via-emerald-950 to-lime-700',
  ember: 'from-stone-950 via-orange-950 to-orange-600',
  slate: 'from-slate-950 via-slate-800 to-slate-600'
}[theme];
---

<article class="space-y-4">
  <div class:list={['project-visual', 'bg-gradient-to-br', themeClasses]}>
    <div class="project-visual-orb"></div>
    <div class="project-visual-copy">
      {visualTitle ? <p class="project-visual-title">{visualTitle}</p> : null}
      {visualSubtitle ? <p class="project-visual-subtitle">{visualSubtitle}</p> : null}
    </div>
  </div>

  <div class="space-y-2">
    <Pill text={category} />
    <h3 class="text-2xl font-bold tracking-tight text-gray-900">{title}</h3>
    <ExpandableText preview={overview} paragraphs={details} buttonLabel="Read full overview" />
  </div>
</article>
