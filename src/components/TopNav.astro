---
export interface NavItem {
  label: string;
  href: string;
}

export interface Props {
  items: NavItem[];
  currentPath?: string;
  brand?: string;
  ctaLabel?: string;
  ctaHref?: string;
}

const {
  items = [],
  currentPath = '/',
  brand = 'TechArch',
  ctaLabel = 'Hire Me',
  ctaHref = '/contact'
} = Astro.props as Props;

const base = import.meta.env.BASE_URL || '/';
const resolveHref = (h: string) => {
  if (!h) return base;
  if (h.startsWith('http') || h.startsWith('#')) return h;
  if (h.startsWith('/')) return base + h.slice(1);
  return base + h;
};

const normalizePath = (path: string) => {
  if (!path) return '/';
  let normalized = path;
  if (normalized.startsWith(base) && base !== '/') {
    normalized = '/' + normalized.slice(base.length);
  }
  normalized = normalized.replace(/\/+/g, '/');
  return normalized.endsWith('/') && normalized.length > 1 ? normalized.slice(0, -1) : normalized;
};

const activePath = normalizePath(currentPath);
---

<header class="nav-gradient backdrop-blur border border-transparent rounded-xl px-5 py-3 shadow-soft mb-8">
  <div class="flex items-center gap-4">
    <div class="flex-1"></div>

    <nav class="flex items-center gap-5 md:gap-7 text-xs md:text-sm font-medium justify-center">
      {items.map((item) => {
        const href = resolveHref(item.href);
        const itemPath = normalizePath(item.href);
        const isActive = itemPath === activePath;
        return (
          <a
            href={href}
            aria-current={isActive ? 'page' : undefined}
            class:list={[
              'transition-colors px-3 py-1.5 rounded-full border',
              isActive
                ? 'text-white border-white/20 bg-white/5 shadow-sm'
                : 'text-white/70 border-transparent hover:text-white hover:bg-white/5'
            ]}
          >
            {item.label}
          </a>
        );
      })}
    </nav>
    <div class="flex-1 flex justify-end">
      <a href={resolveHref(ctaHref)} class="text-xs font-semibold text-white bg-accent px-4 py-2 rounded-full shadow-soft hover:opacity-90 transition-opacity">
        {ctaLabel}
      </a>
    </div>
  </div>
</header>
