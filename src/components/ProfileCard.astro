---
export interface Props {
  image?: string;
  name: string;
  title?: string;
  location?: string;
  email?: string;
}
export interface Link { label: string; href: string; icon?: string }

export interface Props {
  image?: string;
  name: string;
  title?: string;
  location?: string;
  email?: string;
  links?: Link[];
  cv?: string;
}

const { image = '/images/profile.jpg', name, title, location, email, links = [], cv } = Astro.props as Props;
const base = import.meta.env.BASE_URL || '/';
const resolvedImage = image && image.startsWith('/') ? base + image.replace(/^\//, '') : image;
const resolvedCv = cv ? (cv.startsWith('/') ? base + cv.replace(/^\//, '') : cv) : undefined;
---
<div class="profile-card">
  <div class="profile-avatar mb-4">
    <img src={resolvedImage} alt={name} class="profile-avatar-img" width="160" height="160" loading="eager" decoding="async" />
  </div>

  <div class="w-full text-left">
    <h3 class="text-xl font-semibold text-white">{name}</h3>
    {title ? <p class="text-sm text-white mt-2">{title}</p> : null}
    {location ? <p class="text-sm text-white mt-2">{location}</p> : null}

    <div class="mt-4 w-full space-y-2">
    {email ? (
      <a class="flex items-center gap-3 text-sm" href={`mailto:${email}`}>
        <span class="ascii-icon">✉️</span>
        <span>{email}</span>
      </a>
    ) : null}

    {links.length ? (
      <ul class="space-y-2">
        {links.map((l) => (
          <li>
            <a class="flex items-center gap-3 text-sm hover:text-accent" href={l.href} target="_blank" rel="noopener noreferrer">
              <span class="link-icon">
                {l.ascii ? (
                  <span class="ascii-icon">{l.ascii}</span>
                ) : l.icon === 'linkedin' ? (
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M4 4H20V20H4V4Z" stroke="currentColor" stroke-width="1.2"/></svg>
                ) : l.icon === 'github' ? (
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M12 2C7 2 3.5 5.5 3.5 10.5C3.5 14.6 6.3 18 9.7 18.8C10.1 18.9 10.3 18.6 10.3 18.3C10.3 18 10.2 17.2 10.2 16.1C7.7 16.7 7 14.9 7 14.9C6.5 13.7 5.7 13.4 5.7 13.4C4.5 12.7 5.8 12.7 5.8 12.7C7.2 12.8 7.9 14.1 7.9 14.1C9 15.9 10.8 15.4 11.6 15.1C11.7 14.3 12 13.8 12.4 13.5C9.8 13.2 7.1 12.2 7.1 8.7C7.1 7.7 7.4 6.9 7.9 6.3C7.8 6 7.5 5 8 3.8C8 3.8 8.8 3.5 10.2 5C11 4.7 11.9 4.5 12.8 4.5C13.7 4.5 14.6 4.7 15.4 5C16.8 3.5 17.6 3.8 17.6 3.8C18.1 5 17.8 6 17.7 6.3C18.3 6.9 18.6 7.7 18.6 8.7C18.6 12.2 15.9 13.2 13.3 13.5C13.8 13.9 14.2 14.7 14.2 15.9C14.2 17.6 14.1 18.9 14.1 18.3C14.1 18.6 14.3 19 14.7 18.8C18.1 18 20.9 14.6 20.9 10.5C20.9 5.5 17.4 2 12.4 2H12Z" stroke="currentColor" stroke-width="0.8"/></svg>
                ) : l.icon === 'youtube' ? (
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M22 8C22 8 21.2 6.3 20 5.6C18.1 4.7 12 4.7 12 4.7C12 4.7 5.9 4.7 4 5.6C2.8 6.3 2 8 2 8C2 8 2 9.7 2 11.4V12.6C2 14.3 2 16 2 16C2 16 2.8 17.7 4 18.4C5.9 19.3 12 19.3 12 19.3C12 19.3 18.1 19.3 20 18.4C21.2 17.7 22 16 22 16C22 16 22 14.3 22 12.6V11.4C22 9.7 22 8 22 8Z" stroke="currentColor" stroke-width="0.8"/></svg>
                ) : (
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.2"/></svg>
                )}
              </span>
              <span>{l.label}</span>
            </a>
          </li>
        ))}
      </ul>
    ) : null}

    {cv ? (
      <a href={resolvedCv} class="text-xs font-semibold text-white bg-accent px-4 py-2 rounded-full shadow-soft mt-3 inline-block">Download CV</a>
    ) : null}
  </div>
</div>
