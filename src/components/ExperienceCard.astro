---
import Pill from './Pill.astro';

export interface Props {
  role: string;
  company: string;
  range: string;
  highlight?: string;
  badge?: string;
  badgeTone?: 'neutral' | 'accent';
}

const {
  role,
  company,
  range,
  highlight,
  badge,
  badgeTone = 'neutral'
} = Astro.props as Props;
---

<article class="card py-4 px-5">
  <div class="flex items-center justify-between gap-3">
    <div>
      <h3 class="font-semibold text-gray-900 text-sm">{company} {highlight ? <span class="text-accent">| {highlight}</span> : null}</h3>
      <p class="text-xs text-gray-500 mt-1">{role}</p>
      <p class="text-[11px] text-gray-400 mt-1">{range}</p>
    </div>
    {badge ? <Pill text={badge} tone={badgeTone} /> : null}
  </div>
</article>
