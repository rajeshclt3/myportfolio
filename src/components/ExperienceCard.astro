---
const { role, company, range, description, tags = [] } = Astro.props;
---
<div class="card mb-4">
  <div class="flex justify-between items-start">
    <div>
      <h5 class="font-semibold">{role}</h5>
      <div class="text-sm text-gray-500">{company} · <span class="text-xs">{range}</span></div>
    </div>
  </div>
  {description ? <p class="mt-3 text-gray-600 text-sm">{description}</p> : null}
  {tags && tags.length ? (
    <div class="mt-3 flex gap-2 flex-wrap text-xs text-gray-500">
      {tags.map(t => <span class="bg-gray-100 px-2 py-1 rounded">{t}</span>)}
    </div>
  ) : null}
</div>
