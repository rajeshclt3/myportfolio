---
export interface Props {
  title: string;
  company: string;
  location?: string;
  logo?: string;
  range: string;
  badge?: string;
  badgeTone?: 'neutral' | 'accent';
  summary?: string;
  points?: string[];
}

const {
  title,
  company,
  location,
  logo,
  range,
  badge,
  badgeTone = 'neutral',
  summary,
  points = []
} = Astro.props as Props;

const makeInitials = (value: string) => {
  const cleaned = (value || '').replace(/[^A-Za-z0-9\s&-]/g, ' ').trim();
  if (!cleaned) return 'CO';
  const tokens = cleaned
    .split(/[\s&-]+/)
    .filter(Boolean)
    .filter((t) => !['pvt', 'ltd', 'bv', 'inc', 'llc', 'the', 'and', 'technologies', 'machinery'].includes(t.toLowerCase()));

  if (!tokens.length) return cleaned.slice(0, 2).toUpperCase();
  if (tokens.length === 1) return tokens[0].slice(0, 2).toUpperCase();
  return (tokens[0][0] + tokens[1][0]).toUpperCase();
};

const companyLogo = makeInitials(company).slice(0, 4).toUpperCase();

const base = import.meta.env.BASE_URL || '/';
const resolveImage = (p?: string) => {
  if (!p) return null;
  if (p.startsWith('http')) return p;
  if (p.startsWith('/')) return base + p.replace(/^\//, '');
  return base + p;
};

const logoSrc = resolveImage((Astro.props as any).logo || logo);
---

<details class="card card-dark group overflow-hidden" open={false}>
  <summary class="list-none cursor-pointer">
    <div class="flex items-start justify-between gap-4">
      <div>
        <h3 class="font-semibold text-gray-900 text-base">{company} | {title}</h3>
        {location ? <p class="text-xs text-gray-400 mt-1">{location}</p> : null}
        <p class="text-xs text-gray-500 mt-1">{range}</p>
      </div>
      <div class="flex items-center gap-3 shrink-0">
        {logoSrc ? (
          <img src={logoSrc} alt={`${company} logo`} class="experience-img" />
        ) : (
          <span class="experience-logo" aria-hidden="true">{companyLogo}</span>
        )}
        <span class="text-gray-400 text-sm transition-transform group-open:rotate-180">⌄</span>
      </div>
    </div>
  </summary>

  {(summary || points.length) ? (
    <div class="mt-5 border-t border-gray-100 pt-5 space-y-4">
      {summary ? <p class="text-sm leading-6 text-gray-600">{summary}</p> : null}
      {points.length ? (
        <ul class="space-y-3 text-sm leading-6 text-gray-600 list-disc pl-5">
          {points.map((point) => <li>{point}</li>)}
        </ul>
      ) : null}
    </div>
  ) : null}
</details>
