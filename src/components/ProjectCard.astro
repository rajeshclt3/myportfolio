---
const { image = '/placeholder.png', title = '', categories = [], excerpt = '', href = '#' } = Astro.props;
---
<article class="card">
  <a href={href} class="block">
    <img src={image} alt={title} class="w-full rounded-lg mb-4 object-cover h-44 w-full" />
    <h4 class="font-semibold">{title}</h4>
    {categories.length ? <div class="text-xs text-gray-500 mt-1">{categories.join(' • ')}</div> : null}
    {excerpt ? <p class="mt-2 text-gray-600 text-sm">{excerpt}</p> : null}
  </a>
</article>
